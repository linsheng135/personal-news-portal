{
  "name": "personal-news-portal",
  "version": "1.0.0",
  "description": "自动化资讯聚合门户 - 每日抓取AI和赚钱主题，用AI进行大白话总结",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run copy-data",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "crawl": "node src/scripts/main-crawler.js",
    "crawl:ai": "node src/scripts/main-crawler.js --ai-only",
    "crawl:finance": "node src/scripts/main-crawler.js --finance-only",
    "crawl:test": "node src/scripts/main-crawler.js --test",
    "summarize": "node src/scripts/main-crawler.js --summarize-only",
    "test": "echo \"Error: no test specified\" && exit 1",
    "copy-data": "node scripts/copy-data.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.4.7",
    "date-fns": "^3.3.1",
    "axios": "^1.6.2",
    "rss-parser": "^3.13.0",
    "cheerio": "^1.0.0-rc.12",
    "lucide-react": "^0.309.0",
    "openai": "^4.28.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/linsheng135/personal-news-portal.git"
  },
  "keywords": [
    "news",
    "aggregator",
    "ai",
    "personal-finance",
    "automation"
  ],
  "author": "linsheng135",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/linsheng135/personal-news-portal/issues"
  },
  "homepage": "https://linsheng135.github.io/personal-news-portal/"
}